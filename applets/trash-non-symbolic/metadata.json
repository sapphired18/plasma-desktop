{
  "KPackageStructure": "Plasma/Applet",
  "KPlugin": {
    "Id": "org.kde.plasma.trash.nonsymbolic",
    "Name": "Trashcan - Non-Symbolic",
    "Description": "Provides access to the files sent to trash",
    "Icon": "user-trash",
    "License": "GPL-2.0+",
    "Category": "File System",
    "EnabledByDefault": false,
    "Authors": [
      {
        "Name": "Heena",
        "Email": "heena393@gmail.com"
      }
    ],
    "Website": "https://www.kde.org/plasma-desktop",
    "BugReportUrl": "https://bugs.kde.org/enter_bug.cgi?product=plasmashell&component=Trash%20widget"
  },
  "X-Plasma-API-Minimum-Version": "6.0",
  "X-Plasma-DropUrlPatterns": ["trash:/"],
  "X-Plasma-NotificationArea": true,
  "X-Plasma-NotificationAreaCategory": "SystemServices",
  "X-Plasma-Provides": ["org.kde.plasma.trash.nonsymbolic"]
}
